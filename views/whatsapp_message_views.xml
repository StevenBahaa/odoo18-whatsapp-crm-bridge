<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ══════════════════════════════════════════════
         LIST VIEW — Messages
    ══════════════════════════════════════════════ -->
    <record id="view_whatsapp_message_list" model="ir.ui.view">
        <field name="name">whatsapp.message.list</field>
        <field name="model">whatsapp.message</field>
        <field name="arch" type="xml">
            <list string="WhatsApp Messages" create="0" edit="0"
                  decoration-danger="status == 'failed'"
                  decoration-success="status == 'read'"
                  decoration-info="direction == 'inbound'">
                <field name="create_date" string="Date"/>
                <field name="direction" widget="badge"
                       decoration-info="direction == 'inbound'"
                       decoration-success="direction == 'outbound'"/>
                <field name="status" widget="badge"
                       decoration-success="status == 'read' or status == 'delivered'"
                       decoration-warning="status == 'sent' or status == 'received'"
                       decoration-danger="status == 'failed'"/>
                <field name="partner_id" string="Customer"/>
                <field name="lead_id" string="CRM Lead"/>
                <field name="assigned_user_id" string="Salesperson"/>
                <field name="conversation_id" string="Conversation" optional="show"/>
                <field name="message_type" optional="show"/>
                <field name="recipient_phone" string="Phone" optional="show"/>
                <field name="account_id" string="Account" optional="show"/>
                <field name="company_id" optional="hide"/>
                <field name="external_sender_id" string="Sender ID" optional="hide"/>
                <field name="external_message_id" string="Ext. Message ID" optional="hide"/>
                <field name="sent_at" optional="hide"/>
                <field name="delivered_at" optional="hide"/>
                <field name="read_at" optional="hide"/>
                <field name="failed_at" optional="hide"/>
            </list>
        </field>
    </record>

    <!-- ══════════════════════════════════════════════
         FORM VIEW — Messages
    ══════════════════════════════════════════════ -->
    <record id="view_whatsapp_message_form" model="ir.ui.view">
        <field name="name">whatsapp.message.form</field>
        <field name="model">whatsapp.message</field>
        <field name="arch" type="xml">
            <form string="WhatsApp Message" create="0" edit="0">
                <sheet>
                    <div class="oe_title">
                        <h1>
                            <field name="body" readonly="1"
                                   placeholder="(no message body)"
                                   class="oe_read_only"/>
                        </h1>
                    </div>

                    <group>
                        <group string="Message Overview">
                            <field name="direction" widget="badge"
                                   decoration-info="direction == 'inbound'"
                                   decoration-success="direction == 'outbound'"/>
                            <field name="message_type"/>
                            <field name="status" widget="badge"
                                   decoration-success="status == 'read' or status == 'delivered'"
                                   decoration-warning="status == 'sent' or status == 'received'"
                                   decoration-danger="status == 'failed'"/>
                            <field name="account_id"/>
                            <field name="company_id" readonly="1"/>
                            <field name="conversation_id"/>
                            <field name="external_message_id"/>
                        </group>

                        <group string="Customer &amp; CRM">
                            <field name="partner_id"/>
                            <field name="lead_id"/>
                            <field name="assigned_user_id"/>
                            <field name="recipient_phone"/>
                            <field name="external_sender_id"/>
                        </group>
                    </group>

                    <notebook>
                        <!-- ── Message Body Tab ── -->
                        <page string="Message Body" name="body">
                            <field name="body" readonly="1" nolabel="1"
                                   widget="text"
                                   placeholder="(no text body for this message type)"/>
                        </page>

                        <!-- ── Status Timeline Tab ── -->
                        <page string="Status Timeline" name="timeline">
                            <group>
                                <group string="Inbound">
                                    <field name="received_at"/>
                                </group>
                                <group string="Outbound Progression">
                                    <field name="sent_at"/>
                                    <field name="delivered_at"/>
                                    <field name="read_at"/>
                                    <field name="failed_at"/>
                                </group>
                            </group>
                        </page>

                        <!-- ── Error Details Tab ── -->
                        <page string="Error Details" name="errors"
                              invisible="not error_code and not error_message">
                            <group>
                                <field name="error_code"/>
                                <field name="error_message"/>
                            </group>
                        </page>

                        <!-- ── Technical / Raw Payload Tab ── -->
                        <page string="Technical / Raw Payload" name="technical"
                              groups="whatsapp_crm_bridge.group_whatsapp_integration_manager">
                            <group>
                                <field name="payload_preview" readonly="1" string="Payload Preview"/>
                            </group>
                            <separator string="Full Raw Payload"/>
                            <field name="raw_payload" readonly="1" nolabel="1" widget="code"/>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <!-- ══════════════════════════════════════════════
         SEARCH VIEW — Messages
    ══════════════════════════════════════════════ -->
    <record id="view_whatsapp_message_search" model="ir.ui.view">
        <field name="name">whatsapp.message.search</field>
        <field name="model">whatsapp.message</field>
        <field name="arch" type="xml">
            <search string="Search WhatsApp Messages">
                <field name="partner_id" string="Customer"/>
                <field name="lead_id" string="CRM Lead"/>
                <field name="assigned_user_id" string="Salesperson"/>
                <field name="conversation_id" string="Conversation"/>
                <field name="account_id" string="Account"/>
                <field name="recipient_phone" string="Phone"/>
                <field name="external_message_id" string="Ext. Message ID"/>

                <!-- Direction Filters -->
                <filter name="direction_inbound" string="Inbound" domain="[('direction', '=', 'inbound')]"/>
                <filter name="direction_outbound" string="Outbound" domain="[('direction', '=', 'outbound')]"/>
                <separator/>

                <!-- Status Filters -->
                <filter name="status_received" string="Received" domain="[('status', '=', 'received')]"/>
                <filter name="status_sent" string="Sent" domain="[('status', '=', 'sent')]"/>
                <filter name="status_delivered" string="Delivered" domain="[('status', '=', 'delivered')]"/>
                <filter name="status_read" string="Read" domain="[('status', '=', 'read')]"/>
                <filter name="status_failed" string="Failed" domain="[('status', '=', 'failed')]"/>
                <separator/>

                <!-- Relation Filters -->
                <filter name="has_conversation" string="Has Conversation" domain="[('conversation_id', '!=', False)]"/>
                <filter name="has_lead" string="Has CRM Lead" domain="[('lead_id', '!=', False)]"/>
                <filter name="has_customer" string="Has Customer" domain="[('partner_id', '!=', False)]"/>
                <separator/>

                <!-- User Filters -->
                <filter name="my_messages" string="My Messages" domain="[('assigned_user_id', '=', uid)]"/>
                <filter name="assigned" string="Assigned" domain="[('assigned_user_id', '!=', False)]"/>
                <filter name="unassigned" string="Unassigned" domain="[('assigned_user_id', '=', False)]"/>

                <!-- Group By -->
                <group expand="0" string="Group By">
                    <filter name="group_by_status" string="Status" context="{'group_by': 'status'}"/>
                    <filter name="group_by_direction" string="Direction" context="{'group_by': 'direction'}"/>
                    <filter name="group_by_assigned_user" string="Salesperson" context="{'group_by': 'assigned_user_id'}"/>
                    <filter name="group_by_conversation" string="Conversation" context="{'group_by': 'conversation_id'}"/>
                    <filter name="group_by_lead" string="CRM Lead" context="{'group_by': 'lead_id'}"/>
                    <filter name="group_by_partner" string="Customer" context="{'group_by': 'partner_id'}"/>
                    <filter name="group_by_account" string="Account" context="{'group_by': 'account_id'}"/>
                    <filter name="group_by_company" string="Company" context="{'group_by': 'company_id'}"/>
                    <filter name="group_by_create_date" string="Date" context="{'group_by': 'create_date:day'}"/>
                </group>
            </search>
        </field>
    </record>

    <!-- ══════════════════════════════════════════════
         PIVOT VIEW — Messages
    ══════════════════════════════════════════════ -->
    <record id="view_whatsapp_message_pivot" model="ir.ui.view">
        <field name="name">whatsapp.message.pivot</field>
        <field name="model">whatsapp.message</field>
        <field name="arch" type="xml">
            <pivot string="WhatsApp Message Analysis">
                <field name="create_date" interval="day" type="row"/>
                <field name="direction" type="col"/>
                <field name="status" type="col"/>
            </pivot>
        </field>
    </record>

    <!-- ══════════════════════════════════════════════
         GRAPH VIEW — Messages
    ══════════════════════════════════════════════ -->
    <record id="view_whatsapp_message_graph" model="ir.ui.view">
        <field name="name">whatsapp.message.graph</field>
        <field name="model">whatsapp.message</field>
        <field name="arch" type="xml">
            <graph string="WhatsApp Messages" type="bar">
                <field name="status"/>
                <field name="direction"/>
            </graph>
        </field>
    </record>

    <!-- ══════════════════════════════════════════════
         ACTIONS
    ══════════════════════════════════════════════ -->

    <!-- Operational action: list/form first -->
    <record id="action_whatsapp_message" model="ir.actions.act_window">
        <field name="name">WhatsApp Messages</field>
        <field name="res_model">whatsapp.message</field>
        <field name="view_mode">list,form,pivot,graph</field>
        <field name="search_view_id" ref="view_whatsapp_message_search"/>
        <field name="context">{}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                No WhatsApp messages yet.
            </p>
            <p>
                Messages are logged automatically when inbound webhooks are
                received or when a salesperson sends a manual reply.
            </p>
        </field>
    </record>

    <!-- Reporting action: pivot/graph first -->
    <record id="action_whatsapp_message_reporting" model="ir.actions.act_window">
        <field name="name">Message Analysis</field>
        <field name="res_model">whatsapp.message</field>
        <field name="view_mode">pivot,graph,list</field>
        <field name="search_view_id" ref="view_whatsapp_message_search"/>
    </record>

    <!-- ══════════════════════════════════════════════
         MENUS
    ══════════════════════════════════════════════ -->

    <!-- Operations > Messages -->
    <menuitem
        id="menu_whatsapp_message"
        name="Messages"
        parent="menu_whatsapp_crm_operations"
        action="action_whatsapp_message"
        sequence="20"
        groups="whatsapp_crm_bridge.group_whatsapp_crm_user"/>

    <!-- Reporting > Message Analysis -->
    <menuitem
        id="menu_whatsapp_message_reporting"
        name="Message Analysis"
        parent="menu_whatsapp_crm_reporting"
        action="action_whatsapp_message_reporting"
        sequence="10"
        groups="whatsapp_crm_bridge.group_whatsapp_crm_manager"/>

</odoo>
