<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_whatsapp_send_message_wizard_form" model="ir.ui.view">
        <field name="name">whatsapp.send.message.wizard.form</field>
        <field name="model">whatsapp.send.message.wizard</field>
        <field name="arch" type="xml">
            <form string="Send WhatsApp Message">
                <sheet>
                    <div class="oe_title">
                        <h2>Send WhatsApp Message</h2>
                    </div>

                    <group>
                        <group string="Context">
                            <field name="lead_id" readonly="1" invisible="not lead_id"/>
                            <field name="partner_id"/>
                            <field name="conversation_id" readonly="1" invisible="not conversation_id"/>
                        </group>
                        <group string="Delivery">
                            <field name="account_id"/>
                            <field name="phone"/>
                        </group>
                    </group>

                    <separator string="Message"/>
                    <field name="message_body"
                           placeholder="Write your WhatsApp reply here..."
                           nolabel="1"
                           widget="text"/>

                    <div class="text-muted mt-2" style="font-size:0.85em;">
                        <i class="fa fa-info-circle"/> This sends a free-form text message via the
                        Meta WhatsApp Cloud API. Templates and media are not supported in this MVP.
                    </div>
                </sheet>

                <footer>
                    <button
                        name="action_send_message"
                        string="Send Message"
                        type="object"
                        class="btn-primary"
                    />
                    <button
                        string="Cancel"
                        special="cancel"
                        class="btn-secondary"
                    />
                </footer>
            </form>
        </field>
    </record>

    <record id="action_whatsapp_send_message_wizard" model="ir.actions.act_window">
        <field name="name">Send WhatsApp Message</field>
        <field name="res_model">whatsapp.send.message.wizard</field>
        <field name="view_mode">form</field>
        <field name="view_id" ref="view_whatsapp_send_message_wizard_form"/>
        <field name="target">new</field>
    </record>

</odoo>