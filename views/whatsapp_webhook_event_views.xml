<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_whatsapp_webhook_event_list" model="ir.ui.view">
        <field name="name">whatsapp.webhook.event.list</field>
        <field name="model">whatsapp.webhook.event</field>
        <field name="arch" type="xml">
            <list string="WhatsApp Webhook Events" create="0" edit="0">
                <field name="create_date"/>
                <field name="account_id"/>
                <field name="company_id"/>
                <field name="partner_id"/>
                <field name="sender_phone"/>
                <field name="normalized_sender_phone"/>
                <field name="event_type"/>
                <field name="external_event_id"/>
                <field name="processing_status"/>
                <field name="processed_at"/>
            </list>
        </field>
    </record>

    <record id="view_whatsapp_webhook_event_form" model="ir.ui.view">
        <field name="name">whatsapp.webhook.event.form</field>
        <field name="model">whatsapp.webhook.event</field>
        <field name="arch" type="xml">
            <form string="WhatsApp Webhook Event" create="0" edit="0">
                <sheet>
                    <group>
                        <group string="Event">
                            <field name="account_id"/>
                            <field name="company_id"/>
                            <field name="event_type"/>
                            <field name="external_event_id"/>
                            <field name="processing_status"/>
                        </group>
                        <group string="Processing">
                            <field name="create_date"/>
                            <field name="processed_at"/>
                            <field name="error_message"/>
                        </group>
                        <group>
                            <field name="partner_id"/>
                            <field name="sender_phone"/>
                            <field name="normalized_sender_phone"/>
                        </group>
                    </group>

                    <notebook>
                        <page string="Payload Preview">
                            <field name="payload_preview" readonly="1"/>
                        </page>
                        <page string="Raw Payload">
                            <field name="raw_payload" readonly="1" nolabel="1"/>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_whatsapp_webhook_event_search" model="ir.ui.view">
        <field name="name">whatsapp.webhook.event.search</field>
        <field name="model">whatsapp.webhook.event</field>
        <field name="arch" type="xml">
            <search string="Search Webhook Events">
                <field name="account_id"/>
                <field name="external_event_id"/>
                <field name="event_type"/>
                <field name="processing_status"/>

                <filter name="status_pending" string="Pending" domain="[('processing_status', '=', 'pending')]"/>
                <filter name="status_processed" string="Processed" domain="[('processing_status', '=', 'processed')]"/>
                <filter name="status_failed" string="Failed" domain="[('processing_status', '=', 'failed')]"/>
                <filter name="status_ignored" string="Ignored" domain="[('processing_status', '=', 'ignored')]"/>

                <separator/>

                <filter name="event_message" string="Messages" domain="[('event_type', '=', 'message')]"/>
                <filter name="event_status" string="Statuses" domain="[('event_type', '=', 'status')]"/>
                <filter name="event_unknown" string="Unknown" domain="[('event_type', '=', 'unknown')]"/>

                <group expand="0" string="Group By">
                    <filter name="group_by_account" string="Account" context="{'group_by': 'account_id'}"/>
                    <filter name="group_by_company" string="Company" context="{'group_by': 'company_id'}"/>
                    <filter name="group_by_type" string="Event Type" context="{'group_by': 'event_type'}"/>
                    <filter name="group_by_status" string="Processing Status" context="{'group_by': 'processing_status'}"/>
                    <filter name="group_by_create_date" string="Creation Date" context="{'group_by': 'create_date'}"/>
                </group>
            </search>
        </field>
    </record>

    <record id="action_whatsapp_webhook_event" model="ir.actions.act_window">
        <field name="name">Webhook Events</field>
        <field name="res_model">whatsapp.webhook.event</field>
        <field name="view_mode">list,form</field>
        <field name="search_view_id" ref="view_whatsapp_webhook_event_search"/>
        <field name="context">{'search_default_group_by_create_date': 1}</field>
    </record>

    <menuitem
        id="menu_whatsapp_webhook_event"
        name="Webhook Events"
        parent="menu_whatsapp_crm_configuration"
        action="action_whatsapp_webhook_event"
        sequence="20"
        groups="whatsapp_crm_bridge.group_whatsapp_integration_manager"
    />

</odoo>