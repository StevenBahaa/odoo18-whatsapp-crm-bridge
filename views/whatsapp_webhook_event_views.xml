<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ══════════════════════════════════════════════
         LIST VIEW — Webhook Events
    ══════════════════════════════════════════════ -->
    <record id="view_whatsapp_webhook_event_list" model="ir.ui.view">
        <field name="name">whatsapp.webhook.event.list</field>
        <field name="model">whatsapp.webhook.event</field>
        <field name="arch" type="xml">
            <list string="WhatsApp Webhook Events" create="0" edit="0"
                  decoration-danger="processing_status == 'failed'"
                  decoration-success="processing_status == 'processed'"
                  decoration-warning="processing_status == 'pending'"
                  decoration-muted="processing_status == 'ignored'">
                <field name="create_date" string="Received At"/>
                <field name="event_type" widget="badge"
                       decoration-info="event_type == 'message'"
                       decoration-warning="event_type == 'status'"
                       decoration-muted="event_type == 'unknown'"/>
                <field name="processing_status" widget="badge"
                       decoration-success="processing_status == 'processed'"
                       decoration-danger="processing_status == 'failed'"
                       decoration-warning="processing_status == 'pending'"
                       decoration-muted="processing_status == 'ignored'"/>
                <field name="account_id" string="Account"/>
                <field name="sender_phone" string="Sender Phone"/>
                <field name="partner_id" string="Matched Customer"/>
                <field name="lead_id" string="CRM Lead" optional="show"/>
                <field name="assigned_user_id" string="Salesperson" optional="show"/>
                <field name="message_type" optional="show"/>
                <field name="processed_at" optional="hide"/>
                <field name="company_id" optional="hide"/>
                <field name="normalized_sender_phone" optional="hide"/>
                <field name="external_event_id" optional="hide"/>
                <field name="error_message" optional="hide"/>
            </list>
        </field>
    </record>

    <!-- ══════════════════════════════════════════════
         FORM VIEW — Webhook Events
    ══════════════════════════════════════════════ -->
    <record id="view_whatsapp_webhook_event_form" model="ir.ui.view">
        <field name="name">whatsapp.webhook.event.form</field>
        <field name="model">whatsapp.webhook.event</field>
        <field name="arch" type="xml">
            <form string="WhatsApp Webhook Event" create="0" edit="0">
                <sheet>
                    <group>
                        <group string="Event Summary">
                            <field name="account_id"/>
                            <field name="company_id" readonly="1"/>
                            <field name="event_type" widget="badge"
                                   decoration-info="event_type == 'message'"
                                   decoration-warning="event_type == 'status'"
                                   decoration-muted="event_type == 'unknown'"/>
                            <field name="message_type"/>
                            <field name="create_date" string="Received At"/>
                        </group>

                        <group string="Processing Result">
                            <field name="processing_status" widget="badge"
                                   decoration-success="processing_status == 'processed'"
                                   decoration-danger="processing_status == 'failed'"
                                   decoration-warning="processing_status == 'pending'"
                                   decoration-muted="processing_status == 'ignored'"/>
                            <field name="processed_at"/>
                            <field name="error_message" invisible="not error_message"/>
                        </group>
                    </group>

                    <group>
                        <group string="Sender Information">
                            <field name="sender_phone"/>
                            <field name="normalized_sender_phone"/>
                            <field name="sender_name"/>
                            <field name="partner_id"/>
                        </group>

                        <group string="Matching Result">
                            <field name="lead_id"/>
                            <field name="assigned_user_id"/>
                        </group>
                    </group>

                    <group string="Message Content" invisible="not message_body">
                        <field name="message_body" nolabel="1"/>
                    </group>

                    <notebook>
                        <!-- ── Payload Preview Tab ── -->
                        <page string="Payload Preview" name="payload_preview">
                            <field name="payload_preview" readonly="1" nolabel="1"
                                   widget="text"
                                   placeholder="(no preview available)"/>
                        </page>

                        <!-- ── Raw Payload Tab (Technical) ── -->
                        <page string="Raw Payload" name="raw_payload"
                              groups="whatsapp_crm_bridge.group_whatsapp_integration_manager">
                            <separator string="Full Raw Payload from Meta"/>
                            <field name="raw_payload" readonly="1" nolabel="1" widget="code"/>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <!-- ══════════════════════════════════════════════
         SEARCH VIEW — Webhook Events
    ══════════════════════════════════════════════ -->
    <record id="view_whatsapp_webhook_event_search" model="ir.ui.view">
        <field name="name">whatsapp.webhook.event.search</field>
        <field name="model">whatsapp.webhook.event</field>
        <field name="arch" type="xml">
            <search string="Search Webhook Events">
                <field name="account_id" string="Account"/>
                <field name="partner_id" string="Customer"/>
                <field name="lead_id" string="CRM Lead"/>
                <field name="assigned_user_id" string="Salesperson"/>
                <field name="sender_phone" string="Sender Phone"/>
                <field name="external_event_id" string="Ext. Event ID"/>

                <!-- Processing Status Filters -->
                <filter name="status_pending" string="Pending" domain="[('processing_status', '=', 'pending')]"/>
                <filter name="status_processed" string="Processed" domain="[('processing_status', '=', 'processed')]"/>
                <filter name="status_failed" string="Failed" domain="[('processing_status', '=', 'failed')]"/>
                <filter name="status_ignored" string="Ignored" domain="[('processing_status', '=', 'ignored')]"/>
                <separator/>

                <!-- Event Type Filters -->
                <filter name="event_message" string="Messages" domain="[('event_type', '=', 'message')]"/>
                <filter name="event_status" string="Status Updates" domain="[('event_type', '=', 'status')]"/>
                <filter name="event_unknown" string="Unknown" domain="[('event_type', '=', 'unknown')]"/>
                <separator/>

                <!-- Matching Filters -->
                <filter name="has_lead" string="Has CRM Lead" domain="[('lead_id', '!=', False)]"/>
                <filter name="has_customer" string="Has Customer" domain="[('partner_id', '!=', False)]"/>
                <separator/>

                <!-- User Filters -->
                <filter name="my_events" string="My Events" domain="[('assigned_user_id', '=', uid)]"/>
                <filter name="assigned_events" string="Assigned" domain="[('assigned_user_id', '!=', False)]"/>
                <filter name="unassigned_events" string="Unassigned" domain="[('assigned_user_id', '=', False)]"/>

                <!-- Group By -->
                <group expand="0" string="Group By">
                    <filter name="group_by_type" string="Event Type" context="{'group_by': 'event_type'}"/>
                    <filter name="group_by_status" string="Processing Status" context="{'group_by': 'processing_status'}"/>
                    <filter name="group_by_account" string="Account" context="{'group_by': 'account_id'}"/>
                    <filter name="group_by_assigned_user" string="Salesperson" context="{'group_by': 'assigned_user_id'}"/>
                    <filter name="group_by_partner" string="Customer" context="{'group_by': 'partner_id'}"/>
                    <filter name="group_by_company" string="Company" context="{'group_by': 'company_id'}"/>
                    <filter name="group_by_create_date" string="Date" context="{'group_by': 'create_date:day'}"/>
                </group>
            </search>
        </field>
    </record>

    <!-- ══════════════════════════════════════════════
         PIVOT VIEW — Webhook Events
    ══════════════════════════════════════════════ -->
    <record id="view_whatsapp_webhook_event_pivot" model="ir.ui.view">
        <field name="name">whatsapp.webhook.event.pivot</field>
        <field name="model">whatsapp.webhook.event</field>
        <field name="arch" type="xml">
            <pivot string="WhatsApp Webhook Event Analysis">
                <field name="create_date" interval="day" type="row"/>
                <field name="event_type" type="col"/>
                <field name="processing_status" type="col"/>
            </pivot>
        </field>
    </record>

    <!-- ══════════════════════════════════════════════
         GRAPH VIEW — Webhook Events
    ══════════════════════════════════════════════ -->
    <record id="view_whatsapp_webhook_event_graph" model="ir.ui.view">
        <field name="name">whatsapp.webhook.event.graph</field>
        <field name="model">whatsapp.webhook.event</field>
        <field name="arch" type="xml">
            <graph string="WhatsApp Webhook Events" type="bar">
                <field name="processing_status"/>
                <field name="event_type"/>
            </graph>
        </field>
    </record>

    <!-- ══════════════════════════════════════════════
         ACTIONS
    ══════════════════════════════════════════════ -->

    <!-- Operational action: list/form first -->
    <record id="action_whatsapp_webhook_event" model="ir.actions.act_window">
        <field name="name">Webhook Events</field>
        <field name="res_model">whatsapp.webhook.event</field>
        <field name="view_mode">list,form,pivot,graph</field>
        <field name="search_view_id" ref="view_whatsapp_webhook_event_search"/>
        <field name="context">{}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                No webhook events recorded yet.
            </p>
            <p>
                Every inbound WhatsApp webhook payload from Meta is logged here
                for audit, debugging, and traceability purposes.
            </p>
        </field>
    </record>

    <!-- Reporting action: pivot/graph first -->
    <record id="action_whatsapp_webhook_event_reporting" model="ir.actions.act_window">
        <field name="name">Webhook Analysis</field>
        <field name="res_model">whatsapp.webhook.event</field>
        <field name="view_mode">pivot,graph,list</field>
        <field name="search_view_id" ref="view_whatsapp_webhook_event_search"/>
    </record>

    <!-- ══════════════════════════════════════════════
         MENUS
    ══════════════════════════════════════════════ -->

    <!-- Operations > Webhook Events -->
    <menuitem
        id="menu_whatsapp_webhook_event"
        name="Webhook Events"
        parent="menu_whatsapp_crm_operations"
        action="action_whatsapp_webhook_event"
        sequence="30"
        groups="whatsapp_crm_bridge.group_whatsapp_integration_manager"/>

    <!-- Reporting > Webhook Analysis -->
    <menuitem
        id="menu_whatsapp_webhook_event_reporting"
        name="Webhook Analysis"
        parent="menu_whatsapp_crm_reporting"
        action="action_whatsapp_webhook_event_reporting"
        sequence="20"
        groups="whatsapp_crm_bridge.group_whatsapp_crm_manager"/>

</odoo>