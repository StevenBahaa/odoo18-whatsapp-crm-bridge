<?xml version="1.0" encoding="UTF-8"?>
<odoo>

    <record id="module_category_whatsapp_crm_bridge" model="ir.module.category">
        <field name="name">WhatsApp CRM Bridge</field>
        <field name="description">Access groups for WhatsApp CRM Bridge</field>
        <field name="sequence">30</field>
    </record>

    <record id="group_whatsapp_crm_user" model="res.groups">
        <field name="name">WhatsApp CRM User</field>
        <field name="category_id" ref="module_category_whatsapp_crm_bridge"/>
    </record>

    <record id="group_whatsapp_crm_manager" model="res.groups">
        <field name="name">WhatsApp CRM Manager</field>
        <field name="category_id" ref="module_category_whatsapp_crm_bridge"/>
        <field name="implied_ids" eval="[(4, ref('group_whatsapp_crm_user'))]"/>
    </record>

    <record id="group_whatsapp_integration_manager" model="res.groups">
        <field name="name">WhatsApp Integration Manager</field>
        <field name="category_id" ref="module_category_whatsapp_crm_bridge"/>
        <field name="implied_ids" eval="[(4, ref('group_whatsapp_crm_manager'))]"/>
    </record>

</odoo>